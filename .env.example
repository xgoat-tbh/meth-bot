# Meth Bot Environment Configuration

# Discord Bot Token (required)
DISCORD_TOKEN=your_discord_bot_token_here

# Discord Application/Client ID (required for slash command cleanup)
CLIENT_ID=your_discord_client_id_here

# Command Prefix
PREFIX=!

# AI API Configuration (for roast engine)
# Supported: openai, openrouter, or any OpenAI-compatible endpoint
AI_API_URL=https://api.groq.com/openai/v1/chat/completions
AI_API_KEY=your_groq_or_openai_api_key_here
AI_MODEL=llama-3.1-8b-instant

# Gemini API Key (fallback when primary AI API is unavailable)
# Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Database path (relative to project root)
DATABASE_PATH=./data/meth-bot.db

# Log level: error | warn | info | debug
LOG_LEVEL=info

# Node environment
NODE_ENV=production
